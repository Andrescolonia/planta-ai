# Configuracion general
NODE_ENV=development

# Backend
PORT=4000
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
FRONTEND_PREVIEW_PORT=4173

# Usa "auto" para que React consuma la API en el mismo host con puerto 4000.
# Si cambias PORT del backend, fija VITE_API_URL con ese puerto.
# Ejemplo red local: VITE_API_URL=http://IP_DEL_PC:4000/api
VITE_API_URL=auto

# Base de datos local
DATABASE_PATH=./data/planta.sqlite

# Almacenamiento de imagenes
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8

# Modo de analisis: demo u openai
ANALYSIS_MODE=demo

# OpenAI Vision
# Para diagnostico real:
# 1. Define ANALYSIS_MODE=openai
# 2. Copia tu clave real en OPENAI_API_KEY dentro de .env
# 3. Reinicia backend y frontend
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=30000

# Si OpenAI falla, true permite volver al motor demo para no romper una exposicion.
# Para validar errores reales durante desarrollo, usa false.
OPENAI_FALLBACK_TO_DEMO=false
