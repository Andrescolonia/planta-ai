# Configuracion general
NODE_ENV=development

# Backend
PORT=4000
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173

# Frontend
# Usa "auto" para que React consuma la API en el mismo host con puerto 4000.
# Para red local tambien puedes fijar: VITE_API_URL=http://IP_DEL_PC:4000/api
VITE_API_URL=auto

# Base de datos local
DATABASE_PATH=./data/planta.sqlite

# Almacenamiento de imagenes
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8

# Modo de analisis
ANALYSIS_MODE=demo
