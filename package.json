{
  "name": "planta-ai",
  "version": "0.1.0",
  "private": true,
  "description": "MVP local de P.L.A.N.T.A. para apoyo al mantenimiento de zonas verdes.",
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "backup:db": "node server/scripts/backup-db.mjs",
    "restore:db": "node server/scripts/restore-db.mjs",
    "start:backend": "npm run start --workspace server",
    "start:frontend": "npm run preview --workspace client",
    "prestart:home": "npm run backup:db",
    "start:home": "npm run build && npm run start:backend",
    "prestart:home:no-build": "npm run backup:db",
    "start:home:no-build": "npm run start:backend",
    "home:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/check-home.ps1",
    "tunnel:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/check-cloudflare-tunnel.ps1",
    "tunnel:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run-cloudflare-tunnel.ps1",
    "tunnel:quick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run-quick-tunnel.ps1",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace client"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
